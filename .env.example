# BoxBox AI Sales System — Environment Variables
# Copy this file to .env and fill in real values

# ── Meta / Facebook ──────────────────────────────────────────────────────────
META_APP_SECRET=your_meta_app_secret_here
META_PAGE_ACCESS_TOKEN=your_page_access_token_here
META_VERIFY_TOKEN=boxbox_verify_2026

# ── Instagram ────────────────────────────────────────────────────────────────
IG_PAGE_ID=your_instagram_page_id_here

# ── Claude AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL=sqlite:///./boxbox_crm.db

# PostgreSQL (production - uncomment and fill)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/boxbox_crm

# ── LINE Messaging API ────────────────────────────────────────────────────────
# วิธีสร้าง:
#   1. ไปที่ https://developers.line.biz/
#   2. สร้าง Provider → Create a Messaging API channel
#   3. ใส่ Channel Secret และ Channel Access Token จาก Basic settings / Messaging API tab
#   4. LINE_OWNER_USER_ID จะได้มาเมื่อ Add bot เป็นเพื่อนแล้วส่งข้อความครั้งแรก
#      (ระบบจะแสดง User ID ให้อัตโนมัติ)
#
# Webhook URL ที่ต้องใส่ใน LINE Developers Console:
#   https://YOUR_DOMAIN/webhook/line
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_OWNER_USER_ID=your_line_user_id_here

# ── Notification Settings ─────────────────────────────────────────────────────
HOT_LEAD_NOTIFY_THRESHOLD=0.85   # confidence % ก่อน notify เจ้าของ
SALE_NOTIFY_MIN_AMOUNT=500       # ยอดขั้นต่ำ (บาท) ที่จะ notify
DAILY_DIGEST_HOUR=20             # ส่ง daily digest กี่โมง (20 = 20:00)
